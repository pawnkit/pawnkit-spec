{
  "user": "examplecorp",
  "repo": "example-gamemode",
  "entry": "gamemodes/example.pwn",
  "output": "gamemodes/example.amx",
  "preset": "openmp",
  "dependencies": [
    "openmultiplayer/omp-stdlib",
    "pawn-lang/YSI-Includes@5.x",
    "plugin://samp-incognito/samp-streamer-plugin:2.8.2"
  ],
  "dev_dependencies": [
    "pawn-lang/pawn-tests"
  ],
  "build": {
    "args": ["-d3", "-;+"],
    "compiler": {
      "site": "github.com",
      "user": "openmultiplayer",
      "repo": "compiler",
      "version": "3.10.11"
    }
  },
  "runtime": {
    "version": "openmp",
    "mode": "server",
    "rcon_password": "changeme",
    "port": 7777,
    "hostname": "Example open.mp server",
    "maxplayers": 50,
    "filterscripts": [],
    "plugins": ["streamer"]
  },
  "pawnkit": {
    "schemaVersion": 1,
    "profile": "openmp",
    "includePaths": ["include", "vendor/include"],
    "tool": {
      "pawnlint": {
        "profile": "recommended"
      }
    },
    "lockfile": "pawn.lock"
  }
}
